{
  "name": "store-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "clients/*"
  ],
  "scripts": {
    "dev:web": "PATH=\"$PWD/.bin:$PATH\" turbo dev --filter=web",
    "dev:api": "uvicorn apps.api.main:app --reload",
    "dev": "PATH=\"$PWD/.bin:$PATH\" turbo dev",
    "build": "PATH=\"$PWD/.bin:$PATH\" turbo build",
    "lint": "PATH=\"$PWD/.bin:$PATH\" turbo lint",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install",
    "format": "prettier --write .",
    "init-client": "node scripts/init-client.mjs",
    "validate-client": "PATH=\"$PWD/.bin:$PATH\" turbo build --filter=@store-platform/config-schema && node scripts/validate-client.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@store-platform/config-schema": "workspace:*",
    "prettier": "^3.3.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
